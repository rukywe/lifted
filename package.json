{
  "name": "lifted-booking-api",
  "version": "1.0.0",
  "description": "Immigration Advisor Booking API for Lifted",
  "type": "module",
  "scripts": {
    "dev": "(test -f .env || cp .env.example .env) && nodemon --watch src --watch data --ext ts,json --exec \"tsx src/server.ts\"",
    "start": "tsx src/server.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "db:generate": "drizzle-kit generate",
    "db:reset": "rm -f bookings.db && echo 'Database cleared — will reseed on next start'",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.45.0",
    "express": "^5.2.1",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "node-cron": "^4.0.0",
    "pino": "^10.0.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "nodemon": "^3.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
